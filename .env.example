# ═══════════════════════════════════════════════════════════════
# OnChainIn — multi-user + Cardano
# Copy to .env and fill in values, then restart: npm run dev
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED for multi-user online mode ───────────────────────
# 1) Create free project at https://supabase.com
# 2) SQL Editor → paste supabase/migrations/001_onchainin_multiuser.sql → Run
# 3) Settings → API → copy URL + anon public key
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Cardano (on-chain check-in) ───────────────────────────────
# https://blockfrost.io → Preprod project
VITE_BLOCKFROST_PROJECT_ID=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CARDANO_NETWORK=preprod
