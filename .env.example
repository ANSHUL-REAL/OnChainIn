# ═══════════════════════════════════════════════════════════════
# OnChainIn — copy to .env and fill values, then: npm run dev
# ═══════════════════════════════════════════════════════════════

# ── AI (Groq) — real “Create with AI” drafts ─────────────────
# Free key: https://console.groq.com/keys
# Restart dev server / redeploy Vercel after changing.
VITE_GROQ_API_KEY=gsk_your_groq_key_here
# Optional model override (default: llama-3.3-70b-versatile)
# VITE_GROQ_MODEL=llama-3.3-70b-versatile

# ── Multi-user online (Supabase) ─────────────────────────────
# 1) Create project at https://supabase.com
# 2) SQL Editor → run supabase/migrations/001_onchainin_multiuser.sql
# 3) Settings → API → URL + anon/publishable key
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# ── Cardano (on-chain check-in) ──────────────────────────────
# https://blockfrost.io → Preprod project (optional)
VITE_BLOCKFROST_PROJECT_ID=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CARDANO_NETWORK=preprod
